[
    {
        "#": "1",
        "signal": "profile_completeness_score",
        "range / type": "0-100",
        "what it measures": "How much of the profile they've filled in"
    },
    {
        "#": "2",
        "signal": "signup_date",
        "range / type": "date string",
        "what it measures": "When they signed up on Redrob"
    },
    {
        "#": "3",
        "signal": "last_active_date",
        "range / type": "date string",
        "what it measures": "When they last logged in"
    },
    {
        "#": "4",
        "signal": "open_to_work_flag",
        "range / type": "bool",
        "what it measures": "Have they marked themselves available"
    },
    {
        "#": "5",
        "signal": "profile_views_received_30d",
        "range / type": "integer >= 0",
        "what it measures": "How often their profile has been viewed by recruiters in last 30 days"
    },
    {
        "#": "6",
        "signal": "applications_submitted_30d",
        "range / type": "integer >= 0",
        "what it measures": "How many roles they've applied to recently"
    },
    {
        "#": "7",
        "signal": "recruiter_response_rate",
        "range / type": "0.0-1.0",
        "what it measures": "What fraction of recruiter messages they reply to"
    },
    {
        "#": "8",
        "signal": "avg_response_time_hours",
        "range / type": "number >= 0",
        "what it measures": "Median time to respond to a recruiter message"
    },
    {
        "#": "9",
        "signal": "skill_assessment_scores",
        "range / type": "dict[str, 0-100]",
        "what it measures": "Per-skill Redrob assessment scores"
    },
    {
        "#": "10",
        "signal": "connection_count",
        "range / type": "integer >= 0",
        "what it measures": "Number of Redrob connections"
    },
    {
        "#": "11",
        "signal": "endorsements_received",
        "range / type": "integer >= 0",
        "what it measures": "Total skill endorsements received"
    },
    {
        "#": "12",
        "signal": "notice_period_days",
        "range / type": "0-180",
        "what it measures": "Their stated notice period"
    },
    {
        "#": "13",
        "signal": "expected_salary_range_inr_lpa.min / .max",
        "range / type": "number >= 0",
        "what it measures": "Salary expectations in INR lakhs per annum"
    },
    {
        "#": "14",
        "signal": "preferred_work_mode",
        "range / type": "onsite/hybrid/remote/flexible",
        "what it measures": "Their stated work-mode preference"
    },
    {
        "#": "15",
        "signal": "willing_to_relocate",
        "range / type": "bool",
        "what it measures": "Will they relocate if needed"
    },
    {
        "#": "16",
        "signal": "github_activity_score",
        "range / type": "-1 to 100",
        "what it measures": "GitHub commits/contributions score (-1 if no GitHub linked)"
    },
    {
        "#": "17",
        "signal": "search_appearance_30d",
        "range / type": "integer >= 0",
        "what it measures": "How often they show up in recruiter searches"
    },
    {
        "#": "18",
        "signal": "saved_by_recruiters_30d",
        "range / type": "integer >= 0",
        "what it measures": "How many recruiters bookmarked them in last 30 days"
    },
    {
        "#": "19",
        "signal": "interview_completion_rate",
        "range / type": "0.0-1.0",
        "what it measures": "What fraction of interviews they've actually attended"
    },
    {
        "#": "20",
        "signal": "offer_acceptance_rate",
        "range / type": "-1 to 1.0",
        "what it measures": "What fraction of offers they accepted (-1 if no prior offers)"
    },
    {
        "#": "21",
        "signal": "verified_email",
        "range / type": "bool",
        "what it measures": "Whether their email address is verified"
    },
    {
        "#": "22",
        "signal": "verified_phone",
        "range / type": "bool",
        "what it measures": "Whether their phone number is verified"
    },
    {
        "#": "23",
        "signal": "linkedin_connected",
        "range / type": "bool",
        "what it measures": "Whether their LinkedIn account is connected"
    }
]